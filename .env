# .env file for local development configuration.
# DO NOT COMMIT SENSITIVE PRODUCTION KEYS TO VERSION CONTROL.
# Instead, manage them securely in your deployment environment.

# Google Gemini API Key
# Obtain one from Google AI Studio: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# AI Model Name to use for content generation.
# Use `python -c "import google.generativeai as genai; import os; os.environ['GEMINI_API_KEY']='YOUR_API_KEY'; genai.configure(api_key=os.environ['GEMINI_API_KEY']); for m in genai.list_models(): print(m.name)"`
# to discover available models for your API key. (Note: Replace 'YOUR_API_KEY' with your actual key)
# Recommended: 'gemini-1.5-pro-latest' or 'gemini-pro'
AI_MODEL_NAME="gemini-1.5-pro-latest"

# Separate API key for integration tests (optional but recommended)
GEMINI_API_KEY_TEST="YOUR_TEST_GEMINI_API_KEY_HERE"
